# ── Required ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
JWT_SECRET=change-this-to-a-strong-random-secret-at-least-32-chars

# ── Database ─────────────────────────────────────────────────────────
# SQLite (default — no setup needed, auto-created on first run)
DATABASE_PATH=./data/foldforge.db

# MySQL/TiDB (optional — set this to use MySQL instead of SQLite)
# DATABASE_URL=mysql://user:password@host:3306/foldforge

# ── Admin ────────────────────────────────────────────────────────────
ADMIN_EMAIL=your-admin@email.com

# ── Supabase Auth (optional — enables email verification & password reset)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe Payments (optional — enables subscription billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── S3 Storage (optional — enables file downloads vault)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ── AI Chat (optional — enables AI assistant)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
